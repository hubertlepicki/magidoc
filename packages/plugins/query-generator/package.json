{
  "name": "@magidoc/plugin-query-generator",
  "description": "A browser and nodeJS compatible plugin that allows to generate GraphQL Queries and Variables",
  "private": false,
  "version": "6.4.1",
  "type": "module",
  "license": "MIT",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "keywords": [
    "graphql",
    "query",
    "generator",
    "node",
    "browser"
  ],
  "homepage": "https://magidoc.js.org/plugins/graphql-query-generator",
  "repository": {
    "type": "git",
    "url": "https://github.com/magidoc-org/magidoc.git",
    "directory": "packages/plugins/query-generator"
  },
  "scripts": {
    "build": "run-p build:*",
    "build:rollup": "rollup -c",
    "build:tsc": "tsc --build tsconfig.build.json",
    "test": "vitest run --coverage",
    "release": "pnpm publish --no-git-checks --access public"
  },
  "dependencies": {
    "graphql": "16.14.0",
    "lodash": "4.18.1",
    "prettier": "3.8.3"
  },
  "devDependencies": {
    "@types/lodash": "4.17.24",
    "@types/node": "25.7.0",
    "@vitest/coverage-v8": "4.1.6",
    "graphql-query-compress": "1.2.4",
    "rollup": "4.60.3",
    "typescript": "6.0.3",
    "vite": "8.0.12",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "graphql": "16.8.1"
  },
  "files": [
    "build"
  ]
}
