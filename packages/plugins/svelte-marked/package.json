{
  "name": "@magidoc/plugin-svelte-marked",
  "description": "A markdown parser library that renders to svelte components.",
  "type": "module",
  "license": "MIT",
  "version": "6.4.2",
  "svelte": "./build/index.js",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "svelte": "./build/index.js"
    }
  },
  "files": [
    "build"
  ],
  "private": false,
  "keywords": [
    "svelte",
    "magidoc",
    "browser",
    "marked",
    "markdown"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/magidoc-org/magidoc.git",
    "directory": "packages/plugins/svelte-marked"
  },
  "scripts": {
    "dev": "vite dev --port 5175",
    "build": "svelte-kit sync && svelte-package --output build",
    "test": "pnpm check",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "release": "pnpm publish --no-git-checks --access public"
  },
  "dependencies": {
    "github-slugger": "2.0.0",
    "marked": "18.0.3",
    "svelte": "5.55.5"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/kit": "2.59.1",
    "@sveltejs/package": "2.5.7",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@types/node": "25.7.0",
    "@types/prismjs": "1.26.6",
    "svelte-check": "4.4.8",
    "tslib": "2.8.1",
    "typescript": "~6.0.3",
    "vite": "8.0.12"
  }
}
