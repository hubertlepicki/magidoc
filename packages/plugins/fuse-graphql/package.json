{
  "name": "@magidoc/plugin-fuse-graphql",
  "description": "A plugin used to index a GraphQL schema into a Fuse.js search engine.",
  "private": false,
  "version": "6.4.0",
  "type": "module",
  "license": "MIT",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "keywords": [
    "markdown",
    "marked",
    "fuse",
    "magidoc"
  ],
  "homepage": "https://magidoc-org.github.io/magidoc/plugins/fuse-graphql",
  "repository": {
    "type": "git",
    "url": "https://github.com/magidoc-org/magidoc.git",
    "directory": "packages/plugins/fuse-graphql"
  },
  "scripts": {
    "build": "run-p build:*",
    "build:rollup": "rollup -c",
    "build:tsc": "tsc --build tsconfig.build.json",
    "test": "vitest run --coverage",
    "release": "pnpm publish --no-git-checks --access public"
  },
  "dependencies": {
    "@magidoc/plugin-fuse-markdown": "workspace:^",
    "fuse.js": "7.3.0",
    "graphql": "16.14.0",
    "marked": "18.0.3"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@vitest/coverage-v8": "4.1.6",
    "rollup": "4.60.3",
    "typescript": "5.9.3",
    "vite": "8.0.12",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "fuse.js": "6.6.2"
  },
  "files": [
    "build"
  ]
}
